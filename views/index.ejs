<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard | Manajemen Karyawan</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        body {
            background-color: #f4f6f9;
        }
        .sidebar {
            min-height: 100vh;
            background-color: #212529;
            color: white;
        }
        .sidebar a {
            color: #adb5bd;
            text-decoration: none;
            padding: 12px 20px;
            display: block;
            border-radius: 8px;
            margin-bottom: 5px;
            transition: 0.3s;
        }
        .sidebar a:hover, .sidebar a.active {
            background-color: #0d6efd;
            color: white;
        }
        .card {
            border: none;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        }
        .card-header {
            background-color: white;
            border-bottom: 1px solid #f0f0f0;
            border-radius: 12px 12px 0 0 !important;
        }
        .table th {
            font-weight: 600;
            color: #495057;
            background-color: #f8f9fa;
        }
    </style>
</head>
<body>

<div class="d-flex">
    <!-- SIDEBAR -->
    <div class="sidebar p-3" style="width: 260px;">
        <h4 class="text-center mb-4 mt-2 fw-bold">
            <i class="bi bi-buildings text-primary"></i> HRD System
        </h4>
        <hr class="text-secondary">
        <a href="/"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a>
        <a href="/" class="active"><i class="bi bi-people me-2"></i> Data Karyawan</a>
    </div>

    <!-- MAIN CONTENT -->
    <div class="flex-grow-1 p-4">
        <!-- Header Dashboard -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="mb-0 fw-bold">Manajemen Karyawan</h3>
            <div class="badge bg-white text-dark shadow-sm p-2 fs-6">
                <i class="bi bi-person-circle text-primary me-1"></i> Admin
            </div>
        </div>

        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Dashboard</a></li>
                <li class="breadcrumb-item active" aria-current="page">Data Karyawan</li>
            </ol>
        </nav>

        <!-- Card Table -->
        <div class="card mt-2">
            <div class="card-header py-3 d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center">
                    <i class="bi bi-table fs-5 text-primary me-2"></i>
                    <h5 class="mb-0 fw-bold">Daftar Karyawan</h5>
                </div>
                <a href="/tambah" class="btn btn-primary btn-sm px-3 shadow-sm">
                    <i class="bi bi-plus-lg me-1"></i> Tambah Data
                </a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">No</th>
                                <th>Nama Lengkap</th>
                                <th>Jabatan</th>
                                <th>Departemen</th>
                                <th>Gaji (Rp)</th>
                                <th class="text-center pe-4">Aksi</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if(karyawan.length > 0) { %>
                                <% karyawan.forEach((k, index) => { %>
                                    <tr>
                                        <td class="ps-4"><%= index + 1 %></td>
                                        <td class="fw-medium"><%= k.nama %></td>
                                        <td><span class="badge bg-info text-dark bg-opacity-25 border border-info"><%= k.jabatan %></span></td>
                                        <td><%= k.departemen %></td>
                                        <td class="text-success fw-semibold"><%= k.gaji.toLocaleString('id-ID') %></td>
                                        <td class="text-center pe-4">
                                            <a href="/edit/<%= k.id %>" class="btn btn-warning btn-sm shadow-sm" title="Edit">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>
                                            <a href="/hapus/<%= k.id %>" class="btn btn-danger btn-sm shadow-sm" title="Hapus" onclick="return confirm('Yakin ingin menghapus data karyawan ini?')">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="6" class="text-center py-5 text-muted">
                                        <i class="bi bi-inbox fs-1 d-block mb-2 text-secondary"></i>
                                        Belum ada data karyawan.
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>