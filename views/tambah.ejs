<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tambah Karyawan | Dashboard HRD</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <style>
        body {
            background-color: #f4f6f9;
        }
        .sidebar {
            min-height: 100vh;
            background-color: #212529;
            color: white;
        }
        .sidebar a {
            color: #adb5bd;
            text-decoration: none;
            padding: 12px 20px;
            display: block;
            border-radius: 8px;
            margin-bottom: 5px;
            transition: 0.3s;
        }
        .sidebar a:hover, .sidebar a.active {
            background-color: #0d6efd;
            color: white;
        }
        .card {
            border: none;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        }
        .card-header {
            background-color: white;
            border-bottom: 1px solid #f0f0f0;
            border-radius: 12px 12px 0 0 !important;
        }
    </style>
</head>
<body>

<div class="d-flex">
    <!-- SIDEBAR -->
    <div class="sidebar p-3" style="width: 260px;">
        <h4 class="text-center mb-4 mt-2 fw-bold">
            <i class="bi bi-buildings text-primary"></i> HRD System
        </h4>
        <hr class="text-secondary">
        
        <a href="/" class="active"><i class="bi bi-people me-2"></i> Data Karyawan</a>
    </div>

    <!-- MAIN CONTENT -->
    <div class="flex-grow-1 p-4">
        <!-- Header Dashboard -->
        <!-- Header Dashboard dengan Tombol Logout -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="mb-0 fw-bold">Tambah Karyawan Baru</h3> <!-- Ganti teks H3 ini sesuai halaman masing-masing -->
            
            <div class="d-flex align-items-center gap-3">
                <div class="badge bg-white text-dark shadow-sm p-2 fs-6 border">
                    <i class="bi bi-person-circle text-primary me-1"></i> Admin
                </div>
                <a href="/logout" class="btn btn-outline-danger btn-sm shadow-sm" onclick="return confirm('Apakah Anda yakin ingin keluar dari sistem?')">
                    <i class="bi bi-box-arrow-right me-1"></i> Logout
                </a>
            </div>
        </div>

        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Data Karyawan</a></li>
                <li class="breadcrumb-item active" aria-current="page">Tambah Data</li>
            </ol>
        </nav>

        <!-- Form Card -->
        <div class="card mt-2">
            <div class="card-header py-3 d-flex align-items-center">
                <i class="bi bi-person-plus fs-5 text-success me-2"></i>
                <h5 class="mb-0 fw-bold">Form Input Karyawan</h5>
            </div>
            <div class="card-body p-4">
                <form action="/tambah" method="POST">
                    
                    <!-- Baris 1: Nama & Jabatan -->
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-muted fw-bold small">NAMA LENGKAP</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white"><i class="bi bi-person text-secondary"></i></span>
                                <input type="text" name="nama" class="form-control" required placeholder="Masukkan nama lengkap...">
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-muted fw-bold small">JABATAN</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white"><i class="bi bi-briefcase text-secondary"></i></span>
                                <input type="text" name="jabatan" class="form-control" required placeholder="Contoh: Staff IT">
                            </div>
                        </div>
                    </div>

                    <!-- Baris 2: Departemen & Gaji -->
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-muted fw-bold small">DEPARTEMEN</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white"><i class="bi bi-diagram-3 text-secondary"></i></span>
                                <input type="text" name="departemen" class="form-control" required placeholder="Contoh: Teknologi">
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-muted fw-bold small">GAJI (Rp)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light fw-bold">Rp</span>
                                <input type="number" name="gaji" class="form-control" required placeholder="0">
                            </div>
                        </div>
                    </div>

                    <hr class="my-4 text-secondary">
                    
                    <!-- Tombol Aksi -->
                    <div class="d-flex justify-content-end gap-2">
                        <a href="/" class="btn btn-light border px-4"><i class="bi bi-x-lg me-1"></i> Batal</a>
                        <button type="submit" class="btn btn-success px-4"><i class="bi bi-check-circle me-1"></i> Simpan Data</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>